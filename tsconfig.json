{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@fellwork/tsconfig/node",
  "compilerOptions": {
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "tools/**/*.ts",
    "templates/**/*.ts",
    "scripts/**/*.ts"
  ]
}
