{
  "name": "shared-configs",
  "description": "Canonical home for shared developer configs across the Fellwork ecosystem",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "ci": "moon run :ci",
    "release": "moon run :release",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "format": "biome format --write .",
    "check": "biome check .",
    "lint": "biome lint . && oxlint ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@changesets/changelog-github": "^0.5.0",
    "@changesets/cli": "^2.27.0",
    "@fellwork/biome-config": "workspace:*",
    "@fellwork/commitlint-config": "workspace:*",
    "@fellwork/cspell-config": "workspace:*",
    "@fellwork/lefthook-config": "workspace:*",
    "@fellwork/markdownlint-config": "workspace:*",
    "@fellwork/oxlint-config": "workspace:*",
    "@fellwork/release-config": "workspace:*",
    "@fellwork/tsconfig": "workspace:*",
    "@types/bun": "^1.3.13",
    "ajv": "^8.17.0",
    "oxlint": "^0.15.0",
    "rolldown": "^1.0.0-rc.17",
    "rolldown-plugin-dts": "^0.23.2",
    "typescript": "^5.6.2",
    "yaml": "^2.6.0"
  }
}
