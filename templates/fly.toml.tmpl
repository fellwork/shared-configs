app = '{{app_name}}'
primary_region = '{{primary_region}}'

[build]
  dockerfile = 'Dockerfile'

[http_service]
  internal_port = {{internal_port}}
  force_https = true
  auto_stop_machines = 'stop'
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  size = 'shared-cpu-1x'
  memory = '512mb'

[env]
  PORT = '{{internal_port}}'
